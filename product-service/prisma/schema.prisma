generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}
model Product {
  id          String   @id @default(uuid())
  name        String
  description String?
  price       Float
  stock       Int
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([name])
  @@index([price])
}